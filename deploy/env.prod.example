TZ=Asia/Saigon
REGISTRY_HOST=registry.gitlab.com
REGISTRY_IMAGE_BASE=registry.gitlab.com/your-group/your-project
IMAGE_TAG=latest
REGISTRY_USERNAME=gitlab-deploy-token-username
REGISTRY_PASSWORD=gitlab-deploy-token-password

MYSQL_DATABASE=thuetoi
MYSQL_USER=thuetoi_app
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-too

APP_JWT_ACCESS_TOKEN_SECRET=replace-with-a-new-secret-at-least-32-characters
APP_JWT_REFRESH_TOKEN_SECRET=replace-with-a-different-secret-at-least-32-characters
APP_AUTH_REFRESH_COOKIE_SECURE=true
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax
APP_AUTH_REFRESH_COOKIE_DOMAIN=
APP_WEB_ALLOWED_ORIGINS=https://your-domain.example

RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM=Thue Toi <noreply@your-domain.example>

CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
